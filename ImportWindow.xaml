<Window x:Class="EasyRest.ImportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Importar OpenAPI" Width="460" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False"
        Background="#1E1E2E" Foreground="#CDD6F4">
    <StackPanel Margin="18">
        <TextBlock x:Name="TitleText" Text="Importando…" FontSize="15" FontWeight="Bold"/>
        <TextBlock x:Name="FileText" Foreground="{StaticResource OverlayBrush}" FontSize="12"
                   Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
        <ProgressBar x:Name="Progress" IsIndeterminate="True" Margin="0,14,0,0"/>
        <TextBlock x:Name="ResultText" TextWrapping="Wrap" Margin="0,14,0,0" Visibility="Collapsed"
                   FontSize="13" LineHeight="22"/>
        <Button x:Name="OkBtn" Content="Aceptar" Width="100" HorizontalAlignment="Right"
                Margin="0,16,0,0" IsEnabled="False" IsDefault="True" Click="Ok_Click"
                Style="{StaticResource AccentButton}"/>
    </StackPanel>
</Window>
