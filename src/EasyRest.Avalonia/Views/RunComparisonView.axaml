<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:core="clr-namespace:EasyRest;assembly=EasyRest.Core"
             x:Class="EasyRest.Avalonia.Views.RunComparisonView"
             x:DataType="core:RunComparisonTab">
    <Grid Margin="0,8,0,0" ColumnDefinitions="290,10,*">
        <!-- Corridas guardadas -->
        <DockPanel Grid.Column="0">
            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                <Button DockPanel.Dock="Right" Content="↻" Classes="ghost" FontSize="13" Click="Reload_Click"
                        ToolTip.Tip="Recargar corridas guardadas"/>
                <TextBlock Text="CORRIDAS GUARDADAS" FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource OverlayBrush}" VerticalAlignment="Center"/>
            </DockPanel>
            <Border Background="{DynamicResource PanelBrush}" CornerRadius="8" Padding="4">
                <ScrollViewer>
                    <ItemsControl ItemsSource="{Binding Runs}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="core:ComparisonEntry">
                                <Border Classes="cmprow" CornerRadius="6" Padding="8,6" Margin="2">
                                    <DockPanel>
                                        <CheckBox DockPanel.Dock="Left" IsChecked="{Binding Selected}"
                                                  VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <Button DockPanel.Dock="Right" Classes="ghost" Click="Delete_Click" Tag="{Binding}"
                                                VerticalAlignment="Center" ToolTip.Tip="Borrar corrida">
                                            <Path Data="{StaticResource IconTrash}" Stroke="{DynamicResource RedBrush}"
                                                  StrokeThickness="1.4" Width="13" Height="13" Stretch="Uniform"/>
                                        </Button>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Sub}" FontSize="11" Foreground="{DynamicResource OverlayBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </DockPanel>

        <!-- Comparación: tabla + gráfico superpuesto -->
        <DockPanel Grid.Column="2">
            <TextBlock x:Name="EmptyHint" DockPanel.Dock="Top" Margin="0,20,0,0"
                       Text="Marcá dos o más corridas para compararlas." HorizontalAlignment="Center"
                       Foreground="{DynamicResource OverlayBrush}" FontSize="13"/>

            <Border DockPanel.Dock="Bottom" Background="{DynamicResource PanelBrush}" CornerRadius="8"
                    Height="230" Margin="0,10,0,0" Padding="8">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="req/s en el tiempo" FontSize="11" FontWeight="Bold"
                               Foreground="{DynamicResource OverlayBrush}" Margin="2,0,0,4"/>
                    <StackPanel x:Name="Legend" DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="12"
                                Margin="0,4,0,0"/>
                    <Canvas x:Name="ChartCanvas" ClipToBounds="True" SizeChanged="Chart_SizeChanged"/>
                </DockPanel>
            </Border>

            <Border Background="{DynamicResource PanelBrush}" CornerRadius="8" Padding="6">
                <DataGrid x:Name="MetricsGrid" IsReadOnly="True" AutoGenerateColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="CORRIDA" Binding="{Binding Label}" Width="2*"/>
                        <DataGridTextColumn Header="FECHA" Binding="{Binding SavedAt}" Width="145"/>
                        <DataGridTextColumn Header="TOTAL" Binding="{Binding Total}" Width="70"/>
                        <DataGridTextColumn Header="OK" Binding="{Binding Ok}" Width="60"/>
                        <DataGridTextColumn Header="FALL." Binding="{Binding Failed}" Width="60"/>
                        <DataGridTextColumn Header="ERROR" Binding="{Binding ErrorRate, StringFormat='{}{0:0.#}%'}" Width="70"/>
                        <DataGridTextColumn Header="PICO r/s" Binding="{Binding PeakRps}" Width="75"/>
                        <DataGridTextColumn Header="AVG" Binding="{Binding Avg, StringFormat='{}{0:0} ms'}" Width="80"/>
                        <DataGridTextColumn Header="P95" Binding="{Binding P95, StringFormat='{}{0:0} ms'}" Width="80"/>
                        <DataGridTextColumn Header="P99" Binding="{Binding P99, StringFormat='{}{0:0} ms'}" Width="80"/>
                        <DataGridTextColumn Header="MAX" Binding="{Binding Max, StringFormat='{}{0:0} ms'}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </DockPanel>
    </Grid>
</UserControl>
