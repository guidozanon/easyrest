<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="EasyRest.Avalonia.Views.AboutWindow"
        Title="Acerca de EasyRest" Width="380" Height="380"
        CanResize="False" WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Icon="avares://EasyRest/Assets/easyrest.ico" Background="#1E1E2E">
    <StackPanel Margin="28" Spacing="10" HorizontalAlignment="Center">
        <Image Source="avares://EasyRest/Assets/easyrest.png" Width="88" Height="88"/>
        <TextBlock Text="EasyRest" FontSize="26" FontWeight="SemiBold"
                   Foreground="#CDD6F4" HorizontalAlignment="Center"/>
        <TextBlock x:Name="VersionText" FontSize="13" Foreground="#89B4FA"
                   HorizontalAlignment="Center"/>
        <TextBlock Text="Cliente HTTP de escritorio estilo Postman/Bruno."
                   FontSize="13" Foreground="#A6ADC8" TextWrapping="Wrap"
                   TextAlignment="Center" MaxWidth="300" Margin="0,4,0,0"/>
        <Button Content="Ver en GitHub" Click="GitHub_Click"
                HorizontalAlignment="Center" Margin="0,8,0,0"/>
        <TextBlock Text="© 2026 Rentlysoft" FontSize="11" Foreground="#6C7086"
                   HorizontalAlignment="Center" Margin="0,6,0,0"/>
    </StackPanel>
</Window>
