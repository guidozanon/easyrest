<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="EasyRest.Avalonia.Views.WorkspaceWindow"
        Title="Workspace y Git" Width="560" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" CanResize="False" ShowInTaskbar="False"
        Icon="avares://EasyRest/Assets/easyrest.ico"
        Background="#1E1E2E">
    <StackPanel Margin="18" Spacing="0">
        <TextBlock Text="WORKSPACES" FontSize="11" FontWeight="Bold" Foreground="#6C7086"/>
        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#6C7086" Margin="0,4,0,8"
                   Text="Cada workspace es una carpeta con sus colecciones (y opcionalmente su propio repo git). El «Personal» vive en AppData. Los ambientes y settings quedan siempre en AppData: tus tokens no van al repo."/>
        <ListBox x:Name="WorkspaceList" Height="140" SelectionChanged="WorkspaceList_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Spacing="1">
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Path}" FontSize="11" Foreground="#6C7086"
                                   FontFamily="Consolas,Menlo,monospace" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,6,0,0">
            <Button Content="+ Agregar carpeta…" Click="ChooseFolder_Click"/>
            <Button Content="Quitar del listado" Click="Remove_Click"/>
        </StackPanel>

        <TextBlock Text="CLONAR REPO EXISTENTE" FontSize="11" FontWeight="Bold" Foreground="#6C7086" Margin="0,16,0,6"/>
        <DockPanel>
            <Button DockPanel.Dock="Right" Content="Clonar en carpeta…" Click="Clone_Click" Margin="6,0,0,0"/>
            <TextBox x:Name="CloneUrlBox" FontFamily="Consolas,Menlo,monospace" FontSize="12"/>
        </DockPanel>

        <TextBlock Text="GIT" FontSize="11" FontWeight="Bold" Foreground="#6C7086" Margin="0,16,0,6"/>
        <TextBlock x:Name="GitStatusText" FontFamily="Consolas,Menlo,monospace" FontSize="12" TextWrapping="Wrap" Foreground="#CDD6F4"/>
        <DockPanel Margin="0,8,0,0">
            <Button DockPanel.Dock="Right" Content="Conectar remote" Click="SetRemote_Click" Margin="6,0,0,0"/>
            <TextBox x:Name="RemoteUrlBox" FontFamily="Consolas,Menlo,monospace" FontSize="12"/>
        </DockPanel>
        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,8,0,0">
            <Button x:Name="InitBtn" Content="Inicializar repo git" Click="Init_Click"/>
            <Button x:Name="SyncBtn" Content="⇅ Sincronizar ahora" Classes="accent" Click="Sync_Click"/>
        </StackPanel>

        <TextBlock x:Name="ResultText" TextWrapping="Wrap" Margin="0,12,0,0" FontSize="12" IsVisible="False"/>
        <Button Content="Cerrar" Width="100" HorizontalAlignment="Right" Margin="0,14,0,0" Click="Close_Click"/>
    </StackPanel>
</Window>

