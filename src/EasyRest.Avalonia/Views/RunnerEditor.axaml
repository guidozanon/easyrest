<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:core="clr-namespace:EasyRest;assembly=EasyRest.Core"
             xmlns:m="clr-namespace:EasyRest.Models;assembly=EasyRest.Core"
             x:Class="EasyRest.Avalonia.Views.RunnerEditor"
             x:DataType="core:RunnerTab">
    <DockPanel Margin="0,8,0,0">
        <WrapPanel DockPanel.Dock="Top">
            <WrapPanel IsEnabled="{Binding IsNotRunning}">
                <TextBlock Text="Colección" Foreground="{DynamicResource SubtextBrush}" VerticalAlignment="Center" Margin="0,0,6,6"/>
                <ComboBox Width="190" Margin="0,0,14,6" ItemsSource="{Binding Collections}"
                          SelectedItem="{Binding SelectedCollection}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="m:RequestCollection">
                            <TextBlock Text="{Binding Name}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <TextBlock Text="Request" Foreground="{DynamicResource SubtextBrush}" VerticalAlignment="Center" Margin="0,0,6,6"/>
                <ComboBox Width="210" Margin="0,0,14,6" ItemsSource="{Binding RequestOptions}"
                          SelectedItem="{Binding SelectedRequestOption}"/>
                <TextBlock Text="Ambiente" Foreground="{DynamicResource SubtextBrush}" VerticalAlignment="Center" Margin="0,0,6,6"/>
                <ComboBox Width="150" Margin="0,0,14,6" ItemsSource="{Binding EnvOptions}"
                          SelectedItem="{Binding SelectedEnvOption}"/>
                <TextBlock Text="Iteraciones" Foreground="{DynamicResource SubtextBrush}" VerticalAlignment="Center" Margin="0,0,6,6"/>
                <TextBox Width="55" Text="{Binding IterationsText}" Margin="0,0,14,6"
                         ToolTip.Tip="Iteraciones que hace cada usuario virtual"/>
                <TextBlock Text="Usuarios" Foreground="{DynamicResource SubtextBrush}" VerticalAlignment="Center" Margin="0,0,6,6"/>
                <TextBox Width="55" Text="{Binding VirtualUsersText}" Margin="0,0,14,6"
                         ToolTip.Tip="Usuarios virtuales que corren las iteraciones en simultáneo (simulación de carga)"/>
                <TextBlock Text="Delay (ms)" Foreground="{DynamicResource SubtextBrush}" VerticalAlignment="Center" Margin="0,0,6,6"/>
                <TextBox Width="55" Text="{Binding DelayText}" Margin="0,0,14,6"/>
                <CheckBox Content="Frenar en error" IsChecked="{Binding StopOnError}" VerticalAlignment="Center" Margin="0,0,14,6"/>
            </WrapPanel>
            <Button Content="▶ Ejecutar" Classes="accent" Margin="0,0,6,6" IsEnabled="{Binding IsNotRunning}" Click="Run_Click"/>
            <Button Content="■ Detener" Margin="0,0,0,6" IsEnabled="{Binding IsRunning}" Click="Stop_Click"/>
        </WrapPanel>

        <ProgressBar DockPanel.Dock="Top" Margin="0,2,0,10" Maximum="{Binding ProgressMax}" Value="{Binding ProgressValue}"/>

        <UniformGrid DockPanel.Dock="Top" Rows="1" Margin="0,0,0,10">
            <Border Background="{DynamicResource PanelBrush}" CornerRadius="8" Padding="10,7" Margin="0,0,6,0">
                <StackPanel>
                    <TextBlock Text="AVG" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource OverlayBrush}"/>
                    <TextBlock Text="{Binding AvgText}" FontSize="17" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/>
                </StackPanel>
            </Border>
            <Border Background="{DynamicResource PanelBrush}" CornerRadius="8" Padding="10,7" Margin="0,0,6,0">
                <StackPanel>
                    <TextBlock Text="P50" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource OverlayBrush}"/>
                    <TextBlock Text="{Binding P50Text}" FontSize="17" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Background="{DynamicResource PanelBrush}" CornerRadius="8" Padding="10,7" Margin="0,0,6,0">
                <StackPanel>
                    <TextBlock Text="P95" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource OverlayBrush}"/>
                    <TextBlock Text="{Binding P95Text}" FontSize="17" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Background="{DynamicResource PanelBrush}" CornerRadius="8" Padding="10,7" Margin="0,0,6,0">
                <StackPanel>
                    <TextBlock Text="P99" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource OverlayBrush}"/>
                    <TextBlock Text="{Binding P99Text}" FontSize="17" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Background="{DynamicResource PanelBrush}" CornerRadius="8" Padding="10,7" Margin="0,0,6,0">
                <StackPanel>
                    <TextBlock Text="MIN" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource OverlayBrush}"/>
                    <TextBlock Text="{Binding MinText}" FontSize="17" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Background="{DynamicResource PanelBrush}" CornerRadius="8" Padding="10,7" Margin="0,0,6,0">
                <StackPanel>
                    <TextBlock Text="MAX" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource OverlayBrush}"/>
                    <TextBlock Text="{Binding MaxText}" FontSize="17" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Background="{DynamicResource PanelBrush}" CornerRadius="8" Padding="10,7" Margin="0,0,6,0">
                <StackPanel>
                    <TextBlock Text="EXITOSAS" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource OverlayBrush}"/>
                    <TextBlock Text="{Binding OkText}" FontSize="17" FontWeight="Bold" Foreground="{DynamicResource GreenBrush}"/>
                </StackPanel>
            </Border>
            <Border Background="{DynamicResource PanelBrush}" CornerRadius="8" Padding="10,7">
                <StackPanel>
                    <TextBlock Text="FALLIDAS" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource OverlayBrush}"/>
                    <TextBlock Text="{Binding FailText}" FontSize="17" FontWeight="Bold" Foreground="{DynamicResource RedBrush}"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border DockPanel.Dock="Top" Background="{DynamicResource PanelBrush}" CornerRadius="8"
                Height="190" Margin="0,0,0,10" Padding="8">
            <Panel>
                <Canvas x:Name="ChartCanvas" ClipToBounds="True" SizeChanged="Chart_SizeChanged"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Top"
                            Spacing="4" Margin="0,-2,0,0">
                    <Rectangle Width="14" Height="3" Fill="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="req/s" FontSize="10" Foreground="{DynamicResource SubtextBrush}" Margin="0,0,12,0"/>
                    <Rectangle Width="14" Height="3" Fill="{DynamicResource PeachBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="avg ms" FontSize="10" Foreground="{DynamicResource SubtextBrush}"/>
                </StackPanel>
                <TextBlock x:Name="ChartHint" Text="Ejecutá el runner para ver el gráfico"
                           Foreground="{DynamicResource OverlayBrush}" FontSize="11"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Panel>
        </Border>

        <TextBlock DockPanel.Dock="Bottom" Text="{Binding Summary}" FontWeight="SemiBold" Margin="2,8,0,0"
                   Foreground="{DynamicResource TextBrush}"/>

        <Border Background="{DynamicResource PanelBrush}" CornerRadius="8" Padding="6">
            <DataGrid x:Name="ResultsGrid" ItemsSource="{Binding Results}" IsReadOnly="True" AutoGenerateColumns="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" Binding="{Binding Iteration}" Width="46"/>
                    <DataGridTextColumn Header="VU" Binding="{Binding User}" Width="46"/>
                    <DataGridTextColumn Header="REQUEST" Binding="{Binding Name}" Width="2*"/>
                    <DataGridTextColumn Header="MÉTODO" Binding="{Binding Method}" Width="80"/>
                    <DataGridTextColumn Header="STATUS" Binding="{Binding Status}" Width="150"/>
                    <DataGridTextColumn Header="TIEMPO (MS)" Binding="{Binding TimeMs}" Width="100"/>
                    <DataGridTextColumn Header="DETALLE" Binding="{Binding Detail}" Width="2*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </DockPanel>
</UserControl>


