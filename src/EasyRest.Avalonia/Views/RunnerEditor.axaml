<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:EasyRest.Avalonia"
             xmlns:core="clr-namespace:EasyRest;assembly=EasyRest.Core"
             xmlns:m="clr-namespace:EasyRest.Models;assembly=EasyRest.Core"
             x:Class="EasyRest.Avalonia.Views.RunnerEditor"
             x:DataType="core:RunnerTab">
    <UserControl.Resources>
        <conv:NotEmptyConverter x:Key="NotEmpty"/>
    </UserControl.Resources>
    <DockPanel Margin="0,8,0,0">
        <WrapPanel DockPanel.Dock="Top">
            <TextBlock Text="Colección" Foreground="{DynamicResource SubtextBrush}" VerticalAlignment="Center" Margin="0,0,6,6"/>
            <ComboBox Width="190" Margin="0,0,14,6" ItemsSource="{Binding Collections}"
                      SelectedItem="{Binding SelectedCollection}">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="m:RequestCollection">
                        <TextBlock Text="{Binding Name}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock Text="Request" Foreground="{DynamicResource SubtextBrush}" VerticalAlignment="Center" Margin="0,0,6,6"/>
            <ComboBox Width="210" Margin="0,0,14,6" ItemsSource="{Binding RequestOptions}"
                      SelectedItem="{Binding SelectedRequestOption}"/>
            <TextBlock Text="Ambiente" Foreground="{DynamicResource SubtextBrush}" VerticalAlignment="Center" Margin="0,0,6,6"/>
            <ComboBox Width="150" Margin="0,0,14,6" ItemsSource="{Binding EnvOptions}"
                      SelectedItem="{Binding SelectedEnvOption}"/>
            <TextBlock Text="Modo" Foreground="{DynamicResource SubtextBrush}" VerticalAlignment="Center" Margin="0,0,6,6"/>
            <ComboBox Width="120" Margin="0,0,14,6" ItemsSource="{Binding Modes}" SelectedItem="{Binding SelectedMode}"/>
            <TextBlock Text="Iteraciones" Foreground="{DynamicResource SubtextBrush}" VerticalAlignment="Center"
                       Margin="0,0,6,6" IsVisible="{Binding IsIterationsMode}"/>
            <TextBox Width="55" Text="{Binding IterationsText}" Margin="0,0,14,6" IsVisible="{Binding IsIterationsMode}"
                     ToolTip.Tip="Iteraciones que hace cada usuario virtual"/>
            <TextBlock Text="Duración (s)" Foreground="{DynamicResource SubtextBrush}" VerticalAlignment="Center"
                       Margin="0,0,6,6" IsVisible="{Binding IsDurationMode}"/>
            <TextBox Width="55" Text="{Binding DurationText}" Margin="0,0,14,6" IsVisible="{Binding IsDurationMode}"
                     ToolTip.Tip="Segundos que dura la corrida; cada usuario repite las requests hasta cumplirse"/>
            <TextBlock Text="Usuarios" Foreground="{DynamicResource SubtextBrush}" VerticalAlignment="Center" Margin="0,0,6,6"/>
            <TextBox Width="55" Text="{Binding VirtualUsersText}" Margin="0,0,14,6"
                     ToolTip.Tip="Usuarios virtuales que corren las iteraciones en simultáneo (simulación de carga)"/>
            <TextBlock Text="Ramp-up (s)" Foreground="{DynamicResource SubtextBrush}" VerticalAlignment="Center" Margin="0,0,6,6"/>
            <TextBox Width="55" Text="{Binding RampUpText}" Margin="0,0,14,6"
                     ToolTip.Tip="Segundos para ir sumando usuarios de a poco (0 = todos arrancan juntos)"/>
            <TextBlock Text="Delay (ms)" Foreground="{DynamicResource SubtextBrush}" VerticalAlignment="Center" Margin="0,0,6,6"/>
            <TextBox Width="55" Text="{Binding DelayText}" Margin="0,0,14,6"/>
            <CheckBox Content="Frenar en error" IsChecked="{Binding StopOnError}" VerticalAlignment="Center" Margin="0,0,14,6"/>
            <Button Content="▶ Correr" Classes="accent" Margin="0,0,6,6" Click="Run_Click"/>
            <Button Content="⇄ Comparar corridas" Margin="0,0,0,6" Click="Compare_Click"/>
        </WrapPanel>

        <TextBlock DockPanel.Dock="Top" Text="{Binding ConfigError}" Foreground="{DynamicResource RedBrush}"
                   Margin="2,4,0,0" IsVisible="{Binding ConfigError, Converter={StaticResource NotEmpty}}"/>

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
            <Path Data="{StaticResource IconPlay}" Fill="#45475A" Width="46" Height="46" Stretch="Uniform"
                  HorizontalAlignment="Center"/>
            <TextBlock Text="Configurá la carga y tocá «Correr»: se abre una pestaña con la corrida y sus resultados."
                       Foreground="#6C7086" FontSize="14" MaxWidth="440" TextWrapping="Wrap" TextAlignment="Center"/>
        </StackPanel>
    </DockPanel>
</UserControl>
