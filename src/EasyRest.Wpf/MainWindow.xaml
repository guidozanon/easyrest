<Window x:Class="EasyRest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:m="clr-namespace:EasyRest.Models;assembly=EasyRest.Core"
        xmlns:local="clr-namespace:EasyRest"
        Title="EasyRest" Height="840" Width="1360" WindowStartupLocation="CenterScreen"
        Background="#1E1E2E" Foreground="#CDD6F4" FontFamily="Segoe UI" FontSize="13"
        UseLayoutRounding="True">
    <Window.Resources>
        <local:MethodToBrushConverter x:Key="MethodBrush"/>
        <local:TreeChildrenConverter x:Key="TreeChildren"/>
        <local:LogKindToBrushConverter x:Key="LogKindBrush"/>
        <local:TextToVisibilityConverter x:Key="TextToVis"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <DataTemplate x:Key="RequestTabHeader">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding Request.Method}" FontWeight="Bold" FontSize="10.5"
                           VerticalAlignment="Center" Margin="0,0,6,0"
                           Foreground="{Binding Request.Method, Converter={StaticResource MethodBrush}}"/>
                <TextBlock Text="{Binding Request.Name}" VerticalAlignment="Center"
                           MaxWidth="170" TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="*" FontWeight="Bold" Margin="3,0,0,0" VerticalAlignment="Center"
                           Foreground="{StaticResource YellowBrush}"
                           ToolTip="Cambios sin guardar"
                           Visibility="{Binding IsDirty, Converter={StaticResource BoolToVis}}"/>
                <Button Content="✕" FontSize="10" Margin="8,0,0,0"
                        Style="{StaticResource GhostButton}" Click="CloseTab_Click" Tag="{Binding}"/>
            </StackPanel>
        </DataTemplate>
        <DataTemplate x:Key="CollectionTabHeader">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚙" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"
                           Foreground="{StaticResource YellowBrush}"/>
                <TextBlock Text="{Binding Collection.Name}" VerticalAlignment="Center"
                           MaxWidth="170" TextTrimming="CharacterEllipsis"/>
                <Button Content="✕" FontSize="10" Margin="8,0,0,0"
                        Style="{StaticResource GhostButton}" Click="CloseTab_Click" Tag="{Binding}"/>
            </StackPanel>
        </DataTemplate>
        <DataTemplate x:Key="RunnerTabHeader">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="▶" FontSize="10.5" VerticalAlignment="Center" Margin="0,0,6,0"
                           Foreground="{StaticResource GreenBrush}"/>
                <TextBlock Text="Runner" VerticalAlignment="Center"/>
                <Button Content="✕" FontSize="10" Margin="8,0,0,0"
                        Style="{StaticResource GhostButton}" Click="CloseTab_Click" Tag="{Binding}"/>
            </StackPanel>
        </DataTemplate>
        <DataTemplate x:Key="RequestTabContent">
            <local:RequestEditor/>
        </DataTemplate>
        <DataTemplate x:Key="CollectionTabContent">
            <local:CollectionEditor/>
        </DataTemplate>
        <DataTemplate x:Key="RunnerTabContent">
            <local:RunnerEditor/>
        </DataTemplate>

        <local:TabTemplateSelector x:Key="TabHeaderSelector"
                                   RequestTemplate="{StaticResource RequestTabHeader}"
                                   CollectionTemplate="{StaticResource CollectionTabHeader}"
                                   RunnerTemplate="{StaticResource RunnerTabHeader}"/>
        <local:TabTemplateSelector x:Key="TabContentSelector"
                                   RequestTemplate="{StaticResource RequestTabContent}"
                                   CollectionTemplate="{StaticResource CollectionTabContent}"
                                   RunnerTemplate="{StaticResource RunnerTabContent}"/>
    </Window.Resources>
    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Background="{StaticResource PanelBrush}" Padding="12,9"
                BorderBrush="{StaticResource Surface0}" BorderThickness="0,0,0,1">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <TextBlock Text="Ambiente" Foreground="{StaticResource SubtextBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="EnvCombo" Width="190" SelectionChanged="EnvCombo_SelectionChanged"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⚡ EasyRest" Foreground="{StaticResource AccentBrush}" FontSize="17"
                               FontWeight="Bold" VerticalAlignment="Center" Margin="2,0,24,0"/>
                    <Button Content="▶ Runner" Click="Runner_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Barra de estado -->
        <Border DockPanel.Dock="Bottom" Background="{StaticResource CrustBrush}"
                BorderBrush="{StaticResource Surface0}" BorderThickness="0,1,0,0" Padding="8,2">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="GitStatusBtn" Style="{StaticResource GhostButton}" FontSize="11"
                            Content="⎇ workspace" VerticalAlignment="Center" Margin="0,0,10,0"
                            Click="GitStatus_Click"/>
                    <TextBlock x:Name="StatusEnvText" FontSize="11" Foreground="{StaticResource OverlayBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ToggleButton x:Name="VarsToggle" Style="{StaticResource StatusToggleButton}" FontSize="11"
                                  Content="{}{{x}} Variables" ToolTip="Mostrar/ocultar las variables del ambiente activo"
                                  Checked="VarsToggle_Changed" Unchecked="VarsToggle_Changed" Margin="0,0,4,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <ToggleButton x:Name="SidebarToggle" Style="{StaticResource StatusToggleButton}" FontSize="11"
                                  Content="◧ Colecciones" ToolTip="Mostrar/ocultar el panel de colecciones"
                                  IsChecked="True" Checked="SidebarToggle_Changed" Unchecked="SidebarToggle_Changed"
                                  Margin="0,0,4,0"/>
                    <ToggleButton x:Name="LogsToggle" Style="{StaticResource StatusToggleButton}" FontSize="11"
                                  Content="☰ Logs" Checked="LogsToggle_Changed" Unchecked="LogsToggle_Changed"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition x:Name="LogsRow" Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarCol" Width="310"/>
                <ColumnDefinition x:Name="SidebarSplitterCol" Width="4"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition x:Name="VarsSplitterCol" Width="0"/>
                <ColumnDefinition x:Name="VarsCol" Width="0"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <DockPanel Background="{StaticResource PanelBrush}">
                <!-- Filtro + acciones (estilo Bruno) -->
                <Grid DockPanel.Dock="Top" Margin="10,10,10,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid>
                        <TextBox x:Name="FilterBox" Padding="7,4" FontSize="12"
                                 TextChanged="FilterBox_TextChanged"/>
                        <TextBlock x:Name="FilterHint" Text="🜄 Filtrar" IsHitTestVisible="False"
                                   Foreground="{StaticResource OverlayBrush}" FontSize="12"
                                   Margin="9,0,0,0" VerticalAlignment="Center"/>
                    </Grid>
                    <Button Grid.Column="1" Content="+" FontSize="14" Padding="9,1" Margin="6,0,0,0"
                            ToolTip="Nueva colección" Click="NewCollection_Click"/>
                    <Button Grid.Column="2" Content="⋯" FontSize="14" Padding="9,1" Margin="4,0,0,0"
                            ToolTip="Más opciones" Click="SidebarMenu_Click">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Importar OpenAPI" Click="ImportOpenApi_Click"/>
                                <MenuItem Header="Nueva colección" Click="NewCollection_Click"/>
                                <Separator/>
                                <MenuItem Header="Workspace y Git…" Click="Workspace_Click"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </Grid>
                <TextBlock DockPanel.Dock="Top" Text="COLECCIONES" Foreground="{StaticResource OverlayBrush}"
                           FontSize="11" FontWeight="Bold" Margin="14,10,0,6"/>
                <TreeView x:Name="Tree" Padding="6" AllowDrop="True"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          MouseDoubleClick="Tree_MouseDoubleClick"
                          PreviewMouseRightButtonDown="Tree_PreviewMouseRightButtonDown"
                          PreviewMouseLeftButtonDown="Tree_PreviewMouseLeftButtonDown"
                          PreviewMouseMove="Tree_PreviewMouseMove"
                          DragOver="Tree_DragOver" Drop="Tree_Drop" DragLeave="Tree_DragLeave">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                            <Setter Property="Visibility"
                                    Value="{Binding IsVisibleInTree, Converter={StaticResource BoolToVis}}"/>
                            <Setter Property="IsExpanded" Value="{Binding IsExpandedInTree, Mode=TwoWay}"/>
                        </Style>
                    </TreeView.ItemContainerStyle>
                    <TreeView.Resources>
                        <HierarchicalDataTemplate DataType="{x:Type m:RequestCollection}" ItemsSource="{Binding Converter={StaticResource TreeChildren}}">
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Content="⋯" Style="{StaticResource GhostButton}"
                                        FontSize="12" Padding="4,0" Click="RowMenu_Click"
                                        Visibility="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}, Converter={StaticResource BoolToVis}}"/>
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Padding="0,1"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="Doble click para abrir la configuración de la colección"/>
                            </DockPanel>
                        </HierarchicalDataTemplate>
                        <HierarchicalDataTemplate DataType="{x:Type m:Folder}" ItemsSource="{Binding Converter={StaticResource TreeChildren}}">
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Content="⋯" Style="{StaticResource GhostButton}"
                                        FontSize="12" Padding="4,0" Click="RowMenu_Click"
                                        Visibility="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}, Converter={StaticResource BoolToVis}}"/>
                                <TextBlock DockPanel.Dock="Left" Text="📁" FontSize="11" Margin="0,0,6,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Name}" Foreground="{StaticResource SubtextBrush}"
                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            </DockPanel>
                        </HierarchicalDataTemplate>
                        <DataTemplate DataType="{x:Type m:RequestItem}">
                            <DockPanel>
                                <DockPanel.ToolTip>
                                    <ToolTip>
                                        <TextBlock Text="{Binding Name}" MaxWidth="420" TextWrapping="Wrap"/>
                                    </ToolTip>
                                </DockPanel.ToolTip>
                                <Button DockPanel.Dock="Right" Content="⋯" Style="{StaticResource GhostButton}"
                                        FontSize="12" Padding="4,0" Click="RowMenu_Click"
                                        Visibility="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}, Converter={StaticResource BoolToVis}}"/>
                                <TextBlock DockPanel.Dock="Left" Text="{Binding Method}" FontWeight="Bold"
                                           Width="52" FontSize="10.5" VerticalAlignment="Center"
                                           Foreground="{Binding Method, Converter={StaticResource MethodBrush}}"/>
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                            </DockPanel>
                        </DataTemplate>
                    </TreeView.Resources>
                    <TreeView.ContextMenu>
                        <ContextMenu Opened="TreeMenu_Opened">
                            <MenuItem x:Name="MenuOpenTab" Header="Abrir en pestaña" Click="OpenTab_Click"/>
                            <MenuItem x:Name="MenuRunRequest" Header="▶ Ejecutar en Runner" Click="RunRequest_Click"/>
                            <MenuItem x:Name="MenuNewRequest" Header="Nueva request" Click="NewRequest_Click"/>
                            <MenuItem x:Name="MenuNewFolder" Header="Nueva carpeta" Click="NewFolder_Click"/>
                            <MenuItem x:Name="MenuExpandAll" Header="Expandir todo" Click="ExpandAll_Click"/>
                            <MenuItem x:Name="MenuCollapseAll" Header="Contraer todo" Click="CollapseAll_Click"/>
                            <MenuItem x:Name="MenuDuplicate" Header="Duplicar" Click="Duplicate_Click"/>
                            <MenuItem x:Name="MenuRename" Header="Renombrar" Click="Rename_Click"/>
                            <Separator/>
                            <MenuItem x:Name="MenuDelete" Header="Eliminar" Click="Delete_Click"/>
                        </ContextMenu>
                    </TreeView.ContextMenu>
                </TreeView>
            </DockPanel>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch"/>

            <!-- Pestañas de requests -->
            <Grid Grid.Column="2" Margin="10,8,10,10">
                <StackPanel x:Name="Placeholder" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="⚡" FontSize="42" HorizontalAlignment="Center"
                               Foreground="{StaticResource Surface1}"/>
                    <TextBlock Text="Hacé doble click sobre una request para abrirla en una pestaña"
                               Foreground="{StaticResource OverlayBrush}" FontSize="14" Margin="0,10,0,0"/>
                </StackPanel>
                <TabControl x:Name="RequestTabs" Visibility="Collapsed"
                            ItemTemplateSelector="{StaticResource TabHeaderSelector}"
                            ContentTemplateSelector="{StaticResource TabContentSelector}"/>
                <Button Content="+" Width="28" Height="26" FontSize="14" Padding="0"
                        HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,2,0,0"
                        ToolTip="Nueva request (elegís la colección al guardarla)"
                        Click="NewTab_Click"/>
            </Grid>

            <GridSplitter x:Name="VarsSplitter" Grid.Column="3" HorizontalAlignment="Stretch"
                          Visibility="Collapsed"/>

            <!-- Panel de variables del ambiente activo -->
            <Border x:Name="VarsPanel" Grid.Column="4" Visibility="Collapsed"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource Surface0}" BorderThickness="1,0,0,0">
                <DockPanel Margin="10">
                    <DockPanel DockPanel.Dock="Top" Margin="0,2,0,8">
                        <TextBlock Text="VARIABLES" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource OverlayBrush}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="VarsEnvName" FontSize="11" Foreground="{StaticResource AccentBrush}"
                                   VerticalAlignment="Center" Margin="8,0,0,0" TextTrimming="CharacterEllipsis"/>
                    </DockPanel>
                    <StackPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
                        <Button x:Name="SaveVarsBtn" Content="💾 Guardar variables" HorizontalAlignment="Stretch"
                                Click="SaveVars_Click"/>
                        <TextBlock Text="Usalas en las requests como {{nombre}}."
                                   Foreground="{StaticResource OverlayBrush}" FontSize="11" Margin="2,6,0,0"/>
                    </StackPanel>
                    <Grid>
                        <DataGrid x:Name="VarsGrid" AutoGenerateColumns="False" CanUserAddRows="True"
                                  FontFamily="Consolas">
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Header="" Width="30"
                                    Binding="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}"/>
                                <DataGridTextColumn Header="VARIABLE" Width="*"
                                    Binding="{Binding Key, UpdateSourceTrigger=PropertyChanged}"/>
                                <DataGridTextColumn Header="VALOR" Width="*"
                                    Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <TextBlock x:Name="NoEnvText" Text="No hay un ambiente seleccionado.&#10;Elegilo en la barra superior o creá uno en «Ambientes»."
                                   Foreground="{StaticResource OverlayBrush}" TextWrapping="Wrap"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center"
                                   Visibility="Collapsed"/>
                    </Grid>
                </DockPanel>
            </Border>
            </Grid>

            <GridSplitter x:Name="LogsSplitter" Grid.Row="1" Height="4" HorizontalAlignment="Stretch"
                          Visibility="Collapsed"/>

            <!-- Panel de logs -->
            <Border x:Name="LogsPanel" Grid.Row="2" Visibility="Collapsed"
                    Background="{StaticResource CrustBrush}"
                    BorderBrush="{StaticResource Surface0}" BorderThickness="0,1,0,0">
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="10,6,10,4">
                        <Button DockPanel.Dock="Right" Content="Limpiar" Style="{StaticResource GhostButton}"
                                FontSize="11" Click="ClearLogs_Click"/>
                        <TextBlock Text="LOGS" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource OverlayBrush}" VerticalAlignment="Center"/>
                    </DockPanel>
                    <ScrollViewer x:Name="LogsScroll" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled" Padding="10,0,10,6">
                        <ItemsControl x:Name="LogsItems">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Expander Margin="0,1">
                                        <Expander.Header>
                                            <DockPanel>
                                                <TextBlock DockPanel.Dock="Left" Text="{Binding Time}" FontSize="11"
                                                           Foreground="{StaticResource OverlayBrush}"
                                                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                <TextBlock DockPanel.Dock="Left" Text="{Binding Method}" FontWeight="Bold"
                                                           FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"
                                                           Foreground="{Binding Method, Converter={StaticResource MethodBrush}}"/>
                                                <TextBlock DockPanel.Dock="Right" Text="{Binding Meta}" FontSize="11"
                                                           Foreground="{StaticResource OverlayBrush}"
                                                           VerticalAlignment="Center" Margin="10,0,0,0"/>
                                                <TextBlock DockPanel.Dock="Right" Text="{Binding Status}" FontWeight="Bold"
                                                           FontSize="11" Foreground="{Binding Kind, Converter={StaticResource LogKindBrush}}"
                                                           VerticalAlignment="Center" Margin="10,0,0,0"/>
                                                <TextBlock Text="{Binding Url}" FontFamily="Consolas" FontSize="12"
                                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            </DockPanel>
                                        </Expander.Header>
                                        <StackPanel>
                                            <Expander Header="Request Headers">
                                                <TextBox Text="{Binding RequestHeaders, Mode=OneWay}" IsReadOnly="True"
                                                         FontFamily="Consolas" FontSize="12" BorderThickness="0"
                                                         Background="Transparent" MaxHeight="200"
                                                         VerticalScrollBarVisibility="Auto"/>
                                            </Expander>
                                            <Expander Header="Request Body"
                                                      Visibility="{Binding RequestBody, Converter={StaticResource TextToVis}}">
                                                <TextBox Text="{Binding RequestBody, Mode=OneWay}" IsReadOnly="True"
                                                         FontFamily="Consolas" FontSize="12" BorderThickness="0"
                                                         Background="Transparent" MaxHeight="240"
                                                         VerticalScrollBarVisibility="Auto"
                                                         HorizontalScrollBarVisibility="Auto"/>
                                            </Expander>
                                            <Expander Header="Response Headers">
                                                <TextBox Text="{Binding ResponseHeaders, Mode=OneWay}" IsReadOnly="True"
                                                         FontFamily="Consolas" FontSize="12" BorderThickness="0"
                                                         Background="Transparent" MaxHeight="200"
                                                         VerticalScrollBarVisibility="Auto"/>
                                            </Expander>
                                            <Expander Header="Response Body"
                                                      Visibility="{Binding ResponseBody, Converter={StaticResource TextToVis}}">
                                                <TextBox Text="{Binding ResponseBody, Mode=OneWay}" IsReadOnly="True"
                                                         FontFamily="Consolas" FontSize="12" BorderThickness="0"
                                                         Background="Transparent" MaxHeight="280"
                                                         VerticalScrollBarVisibility="Auto"
                                                         HorizontalScrollBarVisibility="Auto"/>
                                            </Expander>
                                        </StackPanel>
                                    </Expander>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>


