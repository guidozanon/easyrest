<Window x:Class="EasyRest.EnvironmentsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ambientes" Height="480" Width="780" WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False" Background="#1E1E2E" Foreground="#CDD6F4">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <DockPanel>
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
                <Button Content="+ Agregar" Padding="8,4" Click="Add_Click"/>
                <Button Content="Renombrar" Padding="8,4" Margin="6,0" Click="Rename_Click"/>
                <Button Content="Eliminar" Padding="8,4" Click="Delete_Click"/>
            </StackPanel>
            <ListBox x:Name="EnvList" DisplayMemberPath="Name" SelectionChanged="EnvList_SelectionChanged"/>
        </DockPanel>

        <DockPanel Grid.Column="2">
            <TextBlock DockPanel.Dock="Top" Margin="0,0,0,6" Foreground="{StaticResource SubtextBrush}"
                       Text="Variables — usalas en las requests como {{nombre}}"/>
            <DataGrid x:Name="VarsGrid" AutoGenerateColumns="False" CanUserAddRows="True"
                      FontFamily="Consolas" IsEnabled="False">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header="" Width="36"
                        Binding="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}"/>
                    <DataGridTextColumn Header="Variable" Width="2*"
                        Binding="{Binding Key, UpdateSourceTrigger=PropertyChanged}"/>
                    <DataGridTextColumn Header="Valor" Width="3*"
                        Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </Grid>
</Window>
