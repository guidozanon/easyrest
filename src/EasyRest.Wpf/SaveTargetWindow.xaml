<Window x:Class="EasyRest.SaveTargetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Guardar request" Width="430" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False"
        Background="#1E1E2E" Foreground="#CDD6F4">
    <StackPanel Margin="18">
        <TextBlock Text="¿Dónde querés guardar la request?" FontWeight="SemiBold" Margin="0,0,0,10"/>
        <ComboBox x:Name="TargetCombo"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Guardar" Width="100" IsDefault="True" Click="Ok_Click"
                    Style="{StaticResource AccentButton}" Margin="0,0,8,0"/>
            <Button Content="Cancelar" Width="100" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
