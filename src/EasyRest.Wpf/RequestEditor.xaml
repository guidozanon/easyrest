<UserControl x:Class="EasyRest.RequestEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:EasyRest"
             xmlns:core="clr-namespace:EasyRest;assembly=EasyRest.Core"
             Foreground="{StaticResource TextBrush}">
    <UserControl.Resources>
        <local:TextToVisibilityConverter x:Key="TextToVis"/>
        <local:AuthTypeToLabelConverter x:Key="AuthLabel"/>
        <local:PassedToIconConverter x:Key="PassIcon"/>
        <local:PassedToBrushConverter x:Key="PassBrush"/>
        <local:JsonKindToBrushConverter x:Key="JsonKindBrush"/>
        <DataTemplate x:Key="AuthTypeItem">
            <TextBlock Text="{Binding Converter={StaticResource AuthLabel}}"/>
        </DataTemplate>
        <HierarchicalDataTemplate DataType="{x:Type core:JsonTreeNode}" ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding Key}" Foreground="{StaticResource AccentBrush}"
                           FontFamily="Consolas" FontSize="12"/>
                <TextBlock Text=":" Foreground="{StaticResource OverlayBrush}"
                           FontFamily="Consolas" FontSize="12" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding Value}" Foreground="{Binding Kind, Converter={StaticResource JsonKindBrush}}"
                           FontFamily="Consolas" FontSize="12" MaxWidth="700"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </HierarchicalDataTemplate>
    </UserControl.Resources>
    <Grid Margin="0,8,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Breadcrumb + acciones -->
        <DockPanel Grid.Row="0">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="💾 Guardar" Click="Save_Click" Margin="0,0,6,0"/>
                <Button Content="⟳ Runner" Click="OpenRunner_Click" Margin="0,0,6,0"
                        ToolTip="Ejecutar esta request en el runner"/>
                <Button Content="↗ Compartir" Click="Share_Click">
                    <Button.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Copiar cURL" Click="CopyCurl_Click"/>
                            <MenuItem Header="Guardar cURL en archivo…" Click="SaveCurl_Click"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>
            </StackPanel>
            <TextBlock DockPanel.Dock="Left" Text="ⓘ" FontSize="15" VerticalAlignment="Center"
                       Margin="2,0,8,0" Foreground="{StaticResource AccentBrush}"
                       Visibility="{Binding Request.Description, Converter={StaticResource TextToVis}}"
                       ToolTipService.ShowDuration="60000" ToolTipService.InitialShowDelay="200">
                <TextBlock.ToolTip>
                    <ToolTip>
                        <TextBlock Text="{Binding Request.Description}" MaxWidth="420" TextWrapping="Wrap"/>
                    </ToolTip>
                </TextBlock.ToolTip>
            </TextBlock>
            <Grid Margin="2,0,10,0">
                <TextBlock x:Name="BreadcrumbText" Text="{Binding Breadcrumb}" FontSize="14"
                           FontWeight="SemiBold" VerticalAlignment="Center" Background="Transparent"
                           TextTrimming="CharacterEllipsis" MouseLeftButtonDown="Breadcrumb_MouseDown">
                    <TextBlock.ToolTip>
                        <ToolTip>
                            <TextBlock Text="{Binding Breadcrumb}"/>
                        </ToolTip>
                    </TextBlock.ToolTip>
                </TextBlock>
                <TextBox x:Name="NameEditBox" FontSize="14" FontWeight="SemiBold" Visibility="Collapsed"
                         KeyDown="NameEdit_KeyDown" LostFocus="NameEdit_LostFocus"/>
            </Grid>
        </DockPanel>

        <!-- Método + URL + Enviar -->
        <DockPanel Grid.Row="1" Margin="0,8,0,0">
            <Button DockPanel.Dock="Right" Content="Enviar" Style="{StaticResource AccentButton}"
                    IsEnabled="{Binding IsNotSending}" Click="Send_Click"/>
            <ComboBox x:Name="MethodCombo" Width="100" SelectedItem="{Binding Request.Method}"
                      FontWeight="Bold" Margin="0,0,6,0"/>
            <TextBox x:Name="UrlBox" Text="{Binding Request.Url, UpdateSourceTrigger=PropertyChanged}"
                     FontFamily="Consolas" VerticalContentAlignment="Center" Margin="0,0,6,0"
                     ToolTip="También podés pegar un comando cURL acá"/>
        </DockPanel>

        <!-- Tabs de la request -->
        <TabControl Grid.Row="2" Margin="0,10,0,0" Background="{StaticResource PanelBrush}" Padding="4">
            <TabItem Header="Params">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Los cambios se reflejan en la URL. Los parámetros desactivados no se envían."
                               Foreground="{StaticResource OverlayBrush}" FontSize="11" Margin="8,6,8,4"/>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Request.QueryParams}" AutoGenerateColumns="False"
                              CanUserAddRows="True" FontFamily="Consolas">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="" Width="36"
                                Binding="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}"/>
                            <DataGridTextColumn Header="PARÁMETRO" Width="2*"
                                Binding="{Binding Key, UpdateSourceTrigger=PropertyChanged}"/>
                            <DataGridTextColumn Header="VALOR" Width="3*"
                                Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="Headers">
                <DataGrid ItemsSource="{Binding Request.Headers}" AutoGenerateColumns="False"
                          CanUserAddRows="True" FontFamily="Consolas">
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Header="" Width="36"
                            Binding="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}"/>
                        <DataGridTextColumn Header="HEADER" Width="2*"
                            Binding="{Binding Key, UpdateSourceTrigger=PropertyChanged}"/>
                        <DataGridTextColumn Header="VALOR" Width="3*"
                            Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Auth">
                <StackPanel Margin="10">
                    <ComboBox x:Name="AuthTypeCombo" Width="240" HorizontalAlignment="Left"
                              ItemTemplate="{StaticResource AuthTypeItem}"
                              SelectedItem="{Binding Request.Auth.Type}" SelectionChanged="AuthType_Changed"/>
                    <TextBlock x:Name="InheritHint" Margin="0,8,0,0" FontSize="11"
                               Foreground="{StaticResource OverlayBrush}"/>
                    <StackPanel x:Name="BearerPanel" Margin="0,12,0,0" Visibility="Collapsed">
                        <TextBlock Text="Token" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Request.Auth.BearerToken, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Consolas"/>
                    </StackPanel>
                    <StackPanel x:Name="BasicPanel" Margin="0,12,0,0" Visibility="Collapsed">
                        <TextBlock Text="Usuario" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Request.Auth.Username, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="Contraseña" Foreground="{StaticResource SubtextBrush}" Margin="0,8,0,4"/>
                        <TextBox Text="{Binding Request.Auth.Password, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Consolas"/>
                    </StackPanel>
                    <StackPanel x:Name="ApiKeyPanel" Margin="0,12,0,0" Visibility="Collapsed">
                        <TextBlock Text="Nombre de la key" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Request.Auth.ApiKeyName, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="Valor" Foreground="{StaticResource SubtextBrush}" Margin="0,8,0,4"/>
                        <TextBox Text="{Binding Request.Auth.ApiKeyValue, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Consolas"/>
                        <TextBlock Text="Enviar en" Foreground="{StaticResource SubtextBrush}" Margin="0,8,0,4"/>
                        <ComboBox x:Name="ApiKeyInCombo" Width="160" HorizontalAlignment="Left"
                                  SelectedItem="{Binding Request.Auth.ApiKeyIn}"/>
                    </StackPanel>
                    <TextBlock Text="Podés usar variables {{nombre}} en cualquiera de estos campos."
                               Foreground="{StaticResource OverlayBrush}" Margin="0,14,0,0" FontSize="11"/>
                </StackPanel>
            </TabItem>
            <TabItem Header="Body">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="8">
                        <ComboBox x:Name="BodyTypeCombo" Width="220"
                                  SelectedItem="{Binding Request.Body.Type}" SelectionChanged="BodyType_Changed"/>
                        <Button x:Name="BeautifyBtn" Content="✦ Beautify" Margin="8,0,0,0" Padding="10,4"
                                Visibility="Collapsed" Click="Beautify_Click"
                                ToolTip="Formatear el JSON (respeta las {{variables}})"/>
                    </StackPanel>
                    <TextBox x:Name="BodyRawBox" Grid.Row="1" Margin="8,0,8,8"
                             Text="{Binding Request.Body.Raw, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" AcceptsTab="True" FontFamily="Consolas"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                             Visibility="Collapsed"/>
                    <TextBlock Grid.Row="2" Margin="10,0,8,8" FontSize="11" TextWrapping="Wrap"
                               Foreground="{StaticResource RedBrush}"
                               Text="{Binding BodyJsonError}"
                               Visibility="{Binding BodyJsonError, Converter={StaticResource TextToVis}}"/>
                    <DataGrid x:Name="FormGrid" Grid.Row="1" Margin="8,0,8,8"
                              ItemsSource="{Binding Request.Body.FormItems}" AutoGenerateColumns="False"
                              CanUserAddRows="True" FontFamily="Consolas" Visibility="Collapsed">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="" Width="36"
                                Binding="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}"/>
                            <DataGridTextColumn Header="CAMPO" Width="2*"
                                Binding="{Binding Key, UpdateSourceTrigger=PropertyChanged}"/>
                            <DataGridTextColumn Header="VALOR" Width="3*"
                                Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="Scripts">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ComboBox x:Name="ScriptViewCombo" Width="240" HorizontalAlignment="Left" Margin="8"
                              SelectionChanged="ScriptView_Changed"/>
                    <TextBox x:Name="PreScriptBox" Grid.Row="1" Margin="8,0,8,4"
                             Text="{Binding Request.PreRequestScript, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" AcceptsTab="True" FontFamily="Consolas" FontSize="12"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                    <TextBox x:Name="TestScriptBox" Grid.Row="1" Margin="8,0,8,4" Visibility="Collapsed"
                             Text="{Binding Request.TestScript, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" AcceptsTab="True" FontFamily="Consolas" FontSize="12"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                    <TextBlock x:Name="ScriptHint" Grid.Row="2" Margin="10,0,8,8" FontSize="11"
                               Foreground="{StaticResource OverlayBrush}" TextWrapping="Wrap"/>
                </Grid>
            </TabItem>
        </TabControl>

        <GridSplitter Grid.Row="3" HorizontalAlignment="Stretch" Height="4" Margin="0,3"/>

        <!-- Respuesta -->
        <Grid Grid.Row="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <DockPanel Margin="2,0,0,6">
                <Button DockPanel.Dock="Right" Content="💾 Guardar respuesta…" FontSize="11"
                        Style="{StaticResource GhostButton}" Click="SaveResponse_Click"
                        ToolTip="Guardar el body de la respuesta en un archivo"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Respuesta" FontWeight="Bold" Margin="0,0,14,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusBrush}"
                               FontWeight="Bold" Margin="0,0,14,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TimeText}" Foreground="{StaticResource OverlayBrush}"
                               Margin="0,0,14,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding SizeText}" Foreground="{StaticResource OverlayBrush}"
                               VerticalAlignment="Center" Margin="0,0,14,0"/>
                    <TextBlock Text="{Binding TestsSummary}" Foreground="{Binding TestsBrush}"
                               FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
            <TabControl Grid.Row="1" Background="{StaticResource PanelBrush}" Padding="4">
                <TabItem Header="Body">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,3,4,3">
                            <TextBlock Text="Vista" Foreground="{StaticResource OverlayBrush}" FontSize="11"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox ItemsSource="{Binding BodyViews}" SelectedItem="{Binding SelectedBodyView}"
                                      Width="85" FontSize="11" Margin="0,0,10,0"/>
                            <TextBlock Text="Ver como" Foreground="{StaticResource OverlayBrush}" FontSize="11"
                                       VerticalAlignment="Center" Margin="0,0,6,0"
                                       Visibility="{Binding BodyTextVisibility}"/>
                            <ComboBox ItemsSource="{Binding Formats}" SelectedItem="{Binding SelectedFormat}"
                                      Width="90" FontSize="11" Visibility="{Binding BodyTextVisibility}"/>
                        </StackPanel>
                        <TextBox Grid.Row="1" Text="{Binding ResponseBody, Mode=OneWay}" IsReadOnly="True"
                                 FontFamily="Consolas" BorderThickness="0" Background="Transparent"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                 Visibility="{Binding BodyTextVisibility}"/>
                        <Grid Grid.Row="1" Visibility="{Binding BodyTreeVisibility}">
                            <TreeView ItemsSource="{Binding ResponseTree}" Padding="4"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                <TreeView.ItemContainerStyle>
                                    <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                    </Style>
                                </TreeView.ItemContainerStyle>
                            </TreeView>
                            <TextBlock Text="{Binding TreeHint}" Foreground="{StaticResource OverlayBrush}"
                                       FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Visibility="{Binding TreeHint, Converter={StaticResource TextToVis}}"/>
                        </Grid>
                    </Grid>
                </TabItem>
                <TabItem Header="Tests">
                    <DockPanel>
                        <TextBox DockPanel.Dock="Bottom" Text="{Binding ScriptOutput, Mode=OneWay}" IsReadOnly="True"
                                 FontFamily="Consolas" FontSize="11" BorderThickness="0" Background="Transparent"
                                 Foreground="{StaticResource SubtextBrush}" MaxHeight="120" Margin="6,4,6,4"
                                 VerticalScrollBarVisibility="Auto"
                                 Visibility="{Binding ScriptOutput, Converter={StaticResource TextToVis}}"/>
                        <Grid>
                            <ItemsControl ItemsSource="{Binding TestResults}" Margin="8,6">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel Margin="0,2">
                                            <TextBlock DockPanel.Dock="Left" Text="{Binding Passed, Converter={StaticResource PassIcon}}" FontWeight="Bold"
                                                       Foreground="{Binding Passed, Converter={StaticResource PassBrush}}" Width="22"/>
                                            <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis"/>
                                        </DockPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="{Binding TestsHint}" Foreground="{StaticResource OverlayBrush}"
                                       FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       TextWrapping="Wrap" MaxWidth="420" TextAlignment="Center"
                                       Visibility="{Binding TestsHint, Converter={StaticResource TextToVis}}"/>
                        </Grid>
                    </DockPanel>
                </TabItem>
                <TabItem Header="Headers">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,3,4,3">
                            <TextBlock Text="Ver como" Foreground="{StaticResource OverlayBrush}" FontSize="11"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox ItemsSource="{Binding HeaderViews}" SelectedItem="{Binding SelectedHeaderView}"
                                      Width="85" FontSize="11"/>
                        </StackPanel>
                        <DataGrid Grid.Row="1" ItemsSource="{Binding ResponseHeaderRows}" IsReadOnly="True"
                                  AutoGenerateColumns="False" FontFamily="Consolas"
                                  Visibility="{Binding HeadersTableVisibility}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="HEADER" Width="*" Binding="{Binding Name}"/>
                                <DataGridTextColumn Header="VALOR" Width="2*" Binding="{Binding Value}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <TextBox Grid.Row="1" Text="{Binding ResponseHeaders, Mode=OneWay}" IsReadOnly="True"
                                 FontFamily="Consolas" BorderThickness="0" Background="Transparent"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                 Visibility="{Binding HeadersRawVisibility}"/>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</UserControl>



